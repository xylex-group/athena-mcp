@startuml
skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontColor black
skinparam ArrowColor black
skinparam rectangle {
  FontColor black
  BorderColor black
  BackgroundColor #E8F1FF
}

title Athena Client Header Resolution (Before)

rectangle "Startup Config" as cfg {
  rectangle "CLI Args\n--athena-client" as cli #FFF2CC
  rectangle "Env\nATHENA_CLIENT" as env #FFF2CC
  rectangle "Fallback\n\"the-ark-of-floris\"" as fb #E2F0D9
}

rectangle "Request Builder" as req #FCE4D6
rectangle "Athena API" as api #F8CECC

cli --> req : prefers if provided
env --> req : else uses env
fb --> req : else fallback
req --> api : X-Athena-Client header

@enduml