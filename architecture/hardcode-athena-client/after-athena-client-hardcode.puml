@startuml
skinparam backgroundColor white
skinparam shadowing false
skinparam defaultFontColor black
skinparam ArrowColor black
skinparam rectangle {
  FontColor black
  BorderColor black
  BackgroundColor #E8F1FF
}

title Athena Client Header Resolution (After)

rectangle "Startup Config" as cfg {
  rectangle "Hardcoded Constant\n\"the-ark-of-floris\"" as hc #D5E8D4
}

rectangle "Request Builder" as req #FCE4D6
rectangle "Athena API" as api #F8CECC

hc --> req : fixed value
req --> api : X-Athena-Client header

@enduml