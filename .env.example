# Base Athena gateway URL
ATHENA_BASE_URL="https://mirror4.athena-cluster.com"

# Athena API key used for gateway, storage, and optional admin calls
ATHENA_API_KEY="api-key-1234567890"

# Default Athena client used when a tool call does not override the client
ATHENA_CLIENT="xylex_cloud"

# Comma-separated allowlist of Athena clients this MCP server may route to
ATHENA_AVAILABLE_CLIENTS="xylex_cloud,analytics"

# When true, admin tools are registered and visible to MCP clients
ATHENA_ADMIN_EXPERIMENTAL_ENABLED="false"

# When true, write-capable tools return an error immediately
READ_ONLY="true"

# Optional health endpoint port. Leave empty to disable the HTTP health server.
HEALTH_PORT=""
