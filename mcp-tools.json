  "definitions": {
    "EmptyRequest": {
      "type": "object",
      "properties": {},
      "required": []
    },
    "CreateTableToolRequest": {
      "type": "object",
      "properties": {
        "table_name": {
          "type": "string",
          "description": "Table name to create"
        },
        "schema_name": {
          "type": "string",
          "description": "Schema name (defaults to public)"
        },
        "columns": {
          "type": "array",
          "description": "Optional column definitions",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string",
                "description": "Column name"
              },
              "data_type": {
                "type": "string",
                "description": "PostgreSQL data type"
              },
              "nullable": {
                "type": "boolean",
                "description": "Whether the column is nullable"
              },
              "default_expression": {
                "type": "string",
                "description": "Optional SQL default expression"
              }
            },
            "required": [
              "name",
              "data_type"
            ]
          }
        },
        "if_not_exists": {
          "type": "boolean",
          "description": "Compatibility flag accepted by Athena"
        }
      },
      "required": [
        "table_name"
      ]
    },
    "EditTableToolRequest": {
      "type": "object",
      "properties": {
        "table_name": {
          "type": "string",
          "description": "Target table name"
        },
        "schema_name": {
          "type": "string",
          "description": "Schema name (defaults to public)"
        },
        "operations": {
          "type": "array",
          "description": "Ordered table alteration operations",
          "items": {
            "type": "object"
          }
        }
      },
      "required": [
        "table_name",
        "operations"
      ]
    },
    "DropTableToolRequest": {
      "type": "object",
      "properties": {
        "table_name": {
          "type": "string",
          "description": "Target table name"
        },
        "schema_name": {
          "type": "string",
          "description": "Schema name (defaults to public)"
        },
        "cascade": {
          "type": "boolean",
          "description": "Whether to cascade the drop"
        }
      },
      "required": [
        "table_name"
      ]
    },
    "DropColumnToolRequest": {
      "type": "object",
      "properties": {
        "table_name": {
          "type": "string",
          "description": "Target table name"
        },
        "column_name": {
          "type": "string",
          "description": "Column name to drop"
        },
        "schema_name": {
          "type": "string",
          "description": "Schema name (defaults to public)"
        },
        "cascade": {
          "type": "boolean",
          "description": "Whether to cascade the drop"
        }
      },
      "required": [
        "table_name",
        "column_name"
      ]
    },
    "CreateIndexToolRequest": {
      "type": "object",
      "properties": {
        "table_name": {
          "type": "string",
          "description": "Target table name"
        },
        "columns": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "description": "Columns included in the index"
        },
        "schema_name": {
          "type": "string",
          "description": "Schema name (defaults to public)"
        },
        "index_name": {
          "type": "string",
          "description": "Optional explicit index name"
        },
        "unique": {
          "type": "boolean",
          "description": "Whether the index is unique"
        },
        "method": {
          "type": "string",
          "description": "Index access method (defaults to btree)"
        }
      },
      "required": [
        "table_name",
        "columns"
      ]
    },
    "DropIndexToolRequest": {
      "type": "object",
